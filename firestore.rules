rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========== HELPER FUNCTIONS ==========
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Check if user is super-admin
    function isSuperAdmin() {
      return isAdmin() && 
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissions.hasAny(['super-admin']);
    }
    
    // Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate timestamp field
    function isValidTimestamp() {
      return request.resource.data is map ? 
        (request.resource.data.keys().hasAll(['createdAt']) ? 
          request.resource.data.createdAt is timestamp : true) : true;
    }
    
    // Validate string field with max length
    function isValidString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }
    
    // ========== USERS COLLECTION ==========

    match /users/{userId} {
      // Allow read if authenticated and it's the user's own doc or user is admin
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());

      // Allow create during sign up (user creates their own doc)
      // Also allow system to create user document on first login
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) &&
                       request.resource.data.keys().hasAll(['email', 'displayName', 'role']) &&
                       request.resource.data.email is string &&
                       request.resource.data.displayName is string;

      // Allow update only by owner (can't change role) or admin
      allow update: if (isOwner(userId) &&
                          !request.resource.data.keys().hasAny(['role', 'isAdmin'])) ||
                       isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();

      // Subcollections under users
      match /savedPlaces/{placeId} {
        allow read, write: if isOwner(userId);
      }

      match /savedRoutes/{routeId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ========== ADMINS COLLECTION ==========

    match /admins/{adminId} {
      // Allow read if authenticated and:
      // 1. Reading own doc, OR
      // 2. Is super admin, OR
      // 3. Is any admin (allow admins to read other admins)
      allow read: if isAuthenticated() &&
                     (isOwner(adminId) ||
                      isSuperAdmin() ||
                      exists(/databases/$(database)/documents/admins/$(request.auth.uid)));

      // Allow create only by super-admins
      allow create: if isSuperAdmin() &&
                       request.resource.data.keys().hasAll(['email', 'name', 'permissions']) &&
                       request.resource.data.email is string &&
                       request.resource.data.name is string &&
                       request.resource.data.permissions is list;

      // Allow update only by super-admins
      allow update: if isSuperAdmin();

      // Allow delete only by super-admins
      allow delete: if isSuperAdmin();
    }
    
    // ========== EVENTS COLLECTION ==========

    match /events/{eventId} {
      // Anyone can read published events
      allow read: if true;

      // Only admins can create events
      allow create: if isAdmin() &&
                       request.resource.data.keys().hasAll(['title', 'startDate', 'endDate']) &&
                       request.resource.data.title is string &&
                       request.resource.data.title.size() > 0 &&
                       request.resource.data.title.size() <= 200 &&
                       request.resource.data.startDate is timestamp &&
                       request.resource.data.endDate is timestamp &&
                       request.resource.data.startDate <= request.resource.data.endDate;

      // Only admins can update events
      allow update: if isAdmin() &&
                       (!request.resource.data.keys().hasAny(['createdAt']) ||
                        request.resource.data.createdAt is timestamp);

      // Only admins can delete events
      allow delete: if isAdmin();
    }

    // ========== PLACES COLLECTION ==========

    match /places/{placeId} {
      // Anyone can read places
      allow read: if true;

      // Only admins can create places
      allow create: if isAdmin() &&
                       request.resource.data.keys().hasAll(['name', 'category']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.name.size() <= 200 &&
                       request.resource.data.category is string &&
                       (request.resource.data.latitude is number ||
                        request.resource.data.location is map) &&
                       (request.resource.data.latitude is number ?
                        request.resource.data.latitude >= -90 &&
                        request.resource.data.latitude <= 90 : true) &&
                       (request.resource.data.longitude is number ?
                        request.resource.data.longitude >= -180 &&
                        request.resource.data.longitude <= 180 : true);

      // Only admins can update places
      allow update: if isAdmin() &&
                       (!request.resource.data.keys().hasAny(['createdAt']) ||
                        request.resource.data.createdAt is timestamp);

      // Only admins can delete places
      allow delete: if isAdmin();
    }

    // ========== ROUTES COLLECTION ==========

    match /routes/{routeId} {
      // Anyone can read routes
      allow read: if true;

      // Only admins can create routes
      allow create: if isAdmin() &&
                       request.resource.data.keys().hasAll(['name', 'routeNumber']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.name.size() <= 200 &&
                       request.resource.data.routeNumber is string &&
                       request.resource.data.routeNumber.size() > 0 &&
                       request.resource.data.routeNumber.size() <= 20;

      // Only admins can update routes
      allow update: if isAdmin() &&
                       (!request.resource.data.keys().hasAny(['createdAt']) ||
                        request.resource.data.createdAt is timestamp);

      // Only admins can delete routes
      allow delete: if isAdmin();
    }

    // ========== JEEPNEYS COLLECTION ==========

    match /jeepneys/{jeepneyId} {
      // Anyone can read jeepneys
      allow read: if true;

      // Only admins can write to jeepneys collection
      allow create: if isAdmin() &&
                       request.resource.data.keys().hasAll(['routeId', 'name']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.name.size() <= 200;

      allow update: if isAdmin() &&
                       (!request.resource.data.keys().hasAny(['createdAt']) ||
                        request.resource.data.createdAt is timestamp);

      allow delete: if isAdmin();
    }

    // ========== PHOTOS COLLECTION ==========

    match /photos/{photoId} {
      // Anyone can read photos
      allow read: if true;

      // Only admins can create/update/delete photos
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ========== PAGE PHOTOS COLLECTION ==========

    match /pagePhotos/{photoId} {
      // Anyone can read page photos (for public pages)
      // Only admins can write/delete page photos
      allow read: if true;
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ========== ANALYTICS COLLECTIONS ==========

    // Analytics Searches - Track place searches
    match /analytics_searches/{searchId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // Analytics Saves - Track place saves
    match /analytics_saves/{saveId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // Analytics Visits - Track completed commutes
    match /analytics_visits/{visitId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // Analytics Foot Traffic - Real-time location tracking
    match /analytics_foot_traffic/{trafficId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // ========== ERROR LOGS COLLECTION ==========

    match /error_logs/{logId} {
      // Only admins can read error logs
      allow read: if isAuthenticated() && isAdmin();
      // Anyone can create error logs (for error monitoring)
      allow create: if true;
      // Only admins can update/delete error logs
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ========== ACTIVITY LOGS COLLECTION ==========

    match /activity_logs/{logId} {
      // Only admins can read activity logs
      allow read: if isAuthenticated() && isAdmin();
      // Authenticated users and admins can create activity logs
      allow create: if isAuthenticated();
      // Only admins can update/delete activity logs
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ========== CONTACT MESSAGES COLLECTION ==========

    match /contactMessages/{messageId} {
      // Anyone can create contact messages (public contact form)
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.name.size() <= 200 &&
                       request.resource.data.email is string &&
                       request.resource.data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
                       request.resource.data.message is string &&
                       request.resource.data.message.size() > 0 &&
                       request.resource.data.message.size() <= 2000;
      // Only admins can read contact messages
      allow read: if isAuthenticated() && isAdmin();
      // Only admins can update/delete contact messages
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ========== DEFAULT DENY ==========
    // Deny all other access not explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
