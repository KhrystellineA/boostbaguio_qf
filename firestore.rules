rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========== HELPER FUNCTIONS ==========
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin (any role)
    function isAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Get the authenticated admin's document data
    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    // Check if user is super-admin (role or permission-based, with legacy fallback)
    function isSuperAdmin() {
      return isAdmin() &&
             (adminDoc().role == 'super_admin' ||
              adminDoc().permissions.hasAny(['super_admin:all', 'super-admin']));
    }

    // Check if user can manage places
    function isPlacesAdmin() {
      return isAdmin() &&
             (adminDoc().role == 'super_admin' ||
              adminDoc().role == 'places_admin' ||
              adminDoc().permissions.hasAny(['super_admin:all', 'places:write']));
    }

    // Check if user can manage routes and jeepneys
    function isRoutesAdmin() {
      return isAdmin() &&
             (adminDoc().role == 'super_admin' ||
              adminDoc().role == 'routes_admin' ||
              adminDoc().permissions.hasAny(['super_admin:all', 'routes:write']));
    }

    // Check if user can manage events
    function isEventsAdmin() {
      return isAdmin() &&
             (adminDoc().role == 'super_admin' ||
              adminDoc().role == 'events_admin' ||
              adminDoc().permissions.hasAny(['super_admin:all', 'events:write']));
    }
    
    // Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate timestamp field
    function isValidTimestamp() {
      return request.resource.data is map ? 
        (request.resource.data.keys().hasAll(['createdAt']) ? 
          request.resource.data.createdAt is timestamp : true) : true;
    }
    
    // Validate string field with max length
    function isValidString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }
    
    // ========== USERS COLLECTION ==========

    match /users/{userId} {
      // Allow read if authenticated and it's the user's own doc or user is admin
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());

      // Allow create during sign up (user creates their own doc)
      // Also allow system to create user document on first login
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) &&
                       request.resource.data.keys().hasAll(['email', 'displayName', 'role']) &&
                       request.resource.data.email is string &&
                       request.resource.data.displayName is string;

      // Allow update only by owner (can't change role) or admin
      allow update: if (isOwner(userId) &&
                          !request.resource.data.keys().hasAny(['role', 'isAdmin'])) ||
                       isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();

      // Subcollections under users
      match /savedPlaces/{placeId} {
        allow read, write: if isOwner(userId);
      }

      match /savedRoutes/{routeId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ========== ADMINS COLLECTION ==========

    match /admins/{adminId} {
      // Allow read if authenticated and:
      // 1. Reading own doc, OR
      // 2. Is super admin, OR
      // 3. Is any admin (allow admins to read other admins)
      allow read: if isAuthenticated() &&
                     (isOwner(adminId) ||
                      isSuperAdmin() ||
                      exists(/databases/$(database)/documents/admins/$(request.auth.uid)));

      // Allow create if:
      // 1. Super admin creating another admin, OR
      // 2. User creating their own admin doc (self-signup)
      allow create: if (isSuperAdmin() &&
                          request.resource.data.keys().hasAll(['email', 'name', 'permissions']) &&
                          request.resource.data.email is string &&
                          request.resource.data.name is string &&
                          request.resource.data.permissions is list) ||
                       (isAuthenticated() && isOwner(adminId) &&
                          request.resource.data.keys().hasAll(['email', 'name', 'role']) &&
                          request.resource.data.email is string &&
                          request.resource.data.name is string &&
                          request.resource.data.role is string);

      // Allow update only by super-admins
      allow update: if isSuperAdmin();

      // Allow delete only by super-admins
      allow delete: if isSuperAdmin();
    }
    
    // ========== EVENTS COLLECTION ==========

    match /events/{eventId} {
      // Anyone can read published events
      allow read: if true;

      // Only events admins (or super admins) can create events
      allow create: if isEventsAdmin() &&
                       request.resource.data.keys().hasAll(['title', 'startDate', 'endDate']) &&
                       request.resource.data.title is string &&
                       request.resource.data.title.size() > 0 &&
                       request.resource.data.title.size() <= 200 &&
                       request.resource.data.startDate is timestamp &&
                       request.resource.data.endDate is timestamp &&
                       request.resource.data.startDate <= request.resource.data.endDate;

      // Only events admins (or super admins) can update events
      allow update: if isEventsAdmin() &&
                       (!request.resource.data.keys().hasAny(['createdAt']) ||
                        request.resource.data.createdAt is timestamp);

      // Only events admins (or super admins) can delete events
      allow delete: if isEventsAdmin();
    }

    // ========== PLACES COLLECTION ==========

    match /places/{placeId} {
      // Anyone can read places
      allow read: if true;

      // Only places admins (or super admins) can create places
      allow create: if isPlacesAdmin() &&
                       request.resource.data.keys().hasAll(['name', 'categories', 'latitude', 'longitude']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.name.size() <= 200 &&
                       request.resource.data.categories is list &&
                       request.resource.data.categories.size() > 0 &&
                       request.resource.data.latitude is number &&
                       request.resource.data.latitude >= -90 &&
                       request.resource.data.latitude <= 90 &&
                       request.resource.data.longitude is number &&
                       request.resource.data.longitude >= -180 &&
                       request.resource.data.longitude <= 180;

      // Only places admins (or super admins) can update places
      allow update: if isPlacesAdmin() &&
                       (!request.resource.data.keys().hasAny(['createdAt']) ||
                        request.resource.data.createdAt is timestamp);

      // Only places admins (or super admins) can delete places
      allow delete: if isPlacesAdmin();
    }

    // ========== ROUTES COLLECTION ==========

    match /routes/{routeId} {
      // Anyone can read routes
      allow read: if true;

      // Only routes admins (or super admins) can create routes
      allow create: if isRoutesAdmin() &&
                       request.resource.data.keys().hasAll(['name', 'routeNumber']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.name.size() <= 200 &&
                       request.resource.data.routeNumber is string &&
                       request.resource.data.routeNumber.size() > 0 &&
                       request.resource.data.routeNumber.size() <= 20;

      // Only routes admins (or super admins) can update routes
      allow update: if isRoutesAdmin() &&
                       (!request.resource.data.keys().hasAny(['createdAt']) ||
                        request.resource.data.createdAt is timestamp);

      // Only routes admins (or super admins) can delete routes
      allow delete: if isRoutesAdmin();
    }

    // ========== JEEPNEYS COLLECTION ==========

    match /jeepneys/{jeepneyId} {
      // Anyone can read jeepneys
      allow read: if true;

      // Only routes admins (or super admins) can write to jeepneys collection
      allow create: if isRoutesAdmin() &&
                       request.resource.data.keys().hasAll(['jeepName', 'terminalLocation', 'endPoint']) &&
                       request.resource.data.jeepName is string &&
                       request.resource.data.jeepName.size() > 0 &&
                       request.resource.data.jeepName.size() <= 200 &&
                       request.resource.data.terminalLocation is string &&
                       request.resource.data.endPoint is string;

      allow update: if isRoutesAdmin() &&
                       (!request.resource.data.keys().hasAny(['createdAt']) ||
                        request.resource.data.createdAt is timestamp);

      allow delete: if isRoutesAdmin();
    }

    // ========== PHOTOS COLLECTION ==========

    match /photos/{photoId} {
      // Anyone can read photos
      allow read: if true;

      // Only admins can create/update/delete photos
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ========== PAGE PHOTOS COLLECTION ==========

    match /pagePhotos/{photoId} {
      // Anyone can read page photos (for public pages)
      // Only admins can write/delete page photos
      allow read: if true;
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ========== ANALYTICS COLLECTIONS ==========

    // Analytics Searches - Track place searches
    match /analytics_searches/{searchId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // Analytics Saves - Track place saves
    match /analytics_saves/{saveId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // Analytics Visits - Track completed commutes
    match /analytics_visits/{visitId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // Analytics Foot Traffic - Real-time location tracking
    match /analytics_foot_traffic/{trafficId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // ========== ERROR LOGS COLLECTION ==========

    match /error_logs/{logId} {
      // Only admins can read error logs
      allow read: if isAuthenticated() && isAdmin();
      // Anyone can create error logs (for error monitoring)
      allow create: if true;
      // Only admins can update/delete error logs
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ========== ACTIVITY LOGS COLLECTION ==========

    match /activity_logs/{logId} {
      // Only admins can read activity logs
      allow read: if isAuthenticated() && isAdmin();
      // Authenticated users and admins can create activity logs
      allow create: if isAuthenticated();
      // Only admins can update/delete activity logs
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ========== CONTACT MESSAGES COLLECTION ==========

    match /contactMessages/{messageId} {
      // Anyone can create contact messages (public contact form)
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.name.size() <= 200 &&
                       request.resource.data.email is string &&
                       request.resource.data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
                       request.resource.data.message is string &&
                       request.resource.data.message.size() > 0 &&
                       request.resource.data.message.size() <= 2000;
      // Only admins can read contact messages
      allow read: if isAuthenticated() && isAdmin();
      // Only admins can update/delete contact messages
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ========== FEATURE REQUESTS COLLECTION ==========
    // Places-admin / events-admin submit pending "feature this place/event"
    // requests; super-admin approves or rejects them from the notifications
    // dropdown. Approval flips `featured: true` on the target doc, which is
    // gated by the existing places/events update rules above.

    match /featureRequests/{requestId} {
      // Any admin can read feature-request docs. Needed so non-super admins
      // can run duplicate-pending checks before submitting a new request, and
      // so the super-admin notifications dropdown can list everything.
      allow read: if isAdmin();

      // Any admin can submit a pending request for a place or event. They
      // must own the requestedBy field (== their uid) and the initial status
      // must be 'pending' so non-super admins can't pre-approve their own.
      allow create: if isAdmin() &&
                       request.resource.data.keys().hasAll([
                         'targetType', 'targetId', 'requestedBy', 'status'
                       ]) &&
                       request.resource.data.targetType in ['place', 'event'] &&
                       request.resource.data.targetId is string &&
                       request.resource.data.targetId.size() > 0 &&
                       request.resource.data.requestedBy == request.auth.uid &&
                       request.resource.data.status == 'pending';

      // Only super admin decides (approve / reject) or deletes a request.
      allow update: if isSuperAdmin() &&
                       request.resource.data.status in ['approved', 'rejected'];
      allow delete: if isSuperAdmin();
    }

    // ========== DEFAULT DENY ==========
    // Deny all other access not explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
