{
  "name": "boost-baguio",
  "version": "0.0.1",
  "description": "Boost Baguio",
  "productName": "Boost Baguio",
  "author": "BaguioBoosters",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "build:analyze": "quasar build --analyze",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "lint:fix": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\" --fix",
    "format": "prettier --write \"**/*.{js,vue,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,vue,html,md,json}\" --ignore-path .gitignore",
    "audit:routes": "node scripts/audit-jeepney-routes.js",
    "audit:routes:osrm": "node scripts/audit-jeepney-routes.js --osrm",
    "prepare": "husky",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@quasar/extras": "^1.16.4",
    "chart.js": "^4.5.1",
    "cropperjs": "^2.1.0",
    "dotenv": "^17.3.1",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.7.0",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "quasar": "^2.16.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.5.22",
    "vue-chartjs": "^5.3.3",
    "vue-cropperjs": "^5.0.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-vite": "^2.1.0",
    "@quasar/vite-plugin": "^1.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.14",
    "prettier": "^3.3.3",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.2.0",
    "workbox-build": "^7.4.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
